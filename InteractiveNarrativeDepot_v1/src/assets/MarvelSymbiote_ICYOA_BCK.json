	{
		"Title": "Incarnation",
		"ItemType": "Group",
		"HeaderText": "This is how you will enter this world.",
		"SelectionLimit": 1,
		"TraitsForVisible": {
			"MatchType": "All",
			"Traits": "Char_Incarnation"
		},
		"OptionItems": [
			{
				"OptionTitle": "Reincarnation",
				"OptionText": "You will be reborn in the world you'll soon inhabit. You may design your appearance and the age at which you regain your memories. You may also design your personality and the choices you made in life up until the very moment that you regain your memories.",
				"ItemType": "Option",
				"Traits": "Char_Incarnation_Reincar"
			},
			{
				"OptionTitle": "Drop-In",
				"OptionText": "You will be dropped into the world you will soon inhabit as you currently are or design your appearance. (You won't gain access to the full character creator.)<br><br>You may choose whether this is a literal drop, as in falling from the sky, or if you are simply teleported onto a back ally somewhere in the world.",
				"ItemType": "Option",
				"Traits": "Char_Incarnation_DropIn"
			},
			{
				"OptionTitle": "Self-Insert",
				"OptionText": "You may choose to take the place of a pre-existing person from the world you will soon inhabit. Whether this is the result of you taking over their mind and soul, merging with them, their untimely death leaving an opening for you to enter, or something else is up to your discretion. (You'll have limited access to the Character Creator.)",
				"ItemType": "Option",
				"Traits": "Char_Incarnation_SelfIns"
			}
		]
	},
